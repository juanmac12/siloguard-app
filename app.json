{
  "expo": {
    "name": "SiloGuard",
    "slug": "SiloGuard",
    "scheme": "siloguard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "dark",
    "web": {
      "bundler": "metro",
      "favicon": "./src/assets/favicon.png"
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
